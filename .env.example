# ─────────────────────────────────────────────────────────────
# Variables de entorno para PoseFlow
# Copia este archivo como .env.local para desarrollo local.
# En Vercel configura estas variables desde el dashboard del proyecto.
# ─────────────────────────────────────────────────────────────

# URL pública de la app (necesaria si usas callbacks o redirects)
# En Vercel se autodefine como VERCEL_URL; solo ponla si tienes dominio propio.
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# (Opcional) URL del backend FastAPI si se despliega por separado
# NEXT_PUBLIC_API_URL=https://tu-backend.onrender.com
